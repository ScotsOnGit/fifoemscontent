  "actionLabel": "EVACUATE",
  "identifyBy": [
    "High lateral: ST elevation in I and aVL >=1mm",
    "Low lateral: ST elevation in V5-V6 >=1mm",
    "Reciprocal ST depression in inferior leads (II, III, aVF)",
    "Often co-exists with anterior or inferior STEMI territory",
    "Isolated lateral STEMI may be due to diagonal or obtuse marginal occlusion"
  ],
  "measurements": {
    "rate": "60-100 bpm",
    "rhythm": "Regular",
    "pWaves": "Normal",
    "prInterval": "120-200ms",
    "qrsDuration": "<120ms",
    "qtInterval": "Normal or prolonged",
    "axis": "Normal or Left",
    "stSegment": "Elevation I, aVL, V5-V6; Reciprocal depression inferior leads"
  },
  "management": [
    "12-lead ECG - confirm lateral ST elevation",
    "Aspirin 300mg PO",
    "GTN sublingual if systolic BP >90mmHg",
    "Analgesia - Morphine or Fentanyl",
    "IV access, continuous monitoring",
    "Urgent evacuation for PCI"
  ],
  "pearls": [
    "Isolated high lateral STEMI (I, aVL only) can be subtle - easily missed on quick glance",
    "Reciprocal inferior ST depression is the key clue when lateral changes are small",
    "Lateral extension of inferior STEMI suggests LCx territory involvement (larger territory)",
    "De Winter pattern may involve lateral leads - check for upsloping ST depression"
  ],
  "differentials": [
    "LVH (lateral ST depression, not elevation)",
    "Early repolarisation",
    "Anterior STEMI with lateral extension",
    "Inferior STEMI with lateral extension"
  ],
