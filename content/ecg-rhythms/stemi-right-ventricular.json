  "actionLabel": "EVACUATE",
  "identifyBy": [
    "ST elevation ≥1mm in right-sided lead V4R (most sensitive and specific)",
    "Usually occurs with inferior STEMI (RCA occlusion)",
    "Classic triad: hypotension + elevated JVP + clear lung fields",
    "ST elevation may extend to V3R–V6R on right-sided ECG",
    "ST elevation in V1 with inferior STEMI also suggests RV involvement"
  ],
  "measurements": {
    "rate": "May be bradycardic",
    "rhythm": "Sinus or Bradycardia",
    "pWaves": "Normal",
    "prInterval": "May be prolonged",
    "qrsDuration": "<120ms",
    "qtInterval": "Normal",
    "axis": "Normal",
    "stSegment": "Elevation V3R–V6R (right-sided leads)"
  },
  "management": [
    "Inferior STEMI protocol - always check right-sided leads",
    "AVOID GTN and other vasodilators - RV is preload-dependent",
    "IV fluid challenge 250–500mL - RV infarct is preload-dependent (BP often improves)",
    "Urgent evacuation",
    "Manage bradycardia with Atropine",
    "Dobutamine may support RV function if fluid unresponsive"
  ],
  "pearls": [
    "GTN is absolutely contraindicated - causes profound hypotension in RV infarct",
    "The right ventricle has little collateral circulation - it relies entirely on the RCA",
    "V4R ST elevation resolves within 12–18 hours - do right-sided ECG early if inferior STEMI suspected",
    "Kussmaul's sign (JVP rising on inspiration) may be present - RV failure finding",
    "RV infarct triad: hypotension + raised JVP + clear lung fields (not heart failure)"
  ],
  "differentials": [
    "Inferior STEMI without RV involvement",
    "Pericarditis (diffuse changes)",
    "PE (right heart strain - different pattern)"
  ],
  "relatedGuidelineIDs": ["acute-coronary-syndrome"],
  "relatedCalculatorIDs": ["heart-score"],
  "tags": ["STEMI", "RV infarct", "right ventricular STEMI", "V4R", "right-sided leads", "ACS", "GTN contraindicated"],
