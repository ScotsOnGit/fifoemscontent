  ],
  "urgency": "urgent",
  "category": "stemi",
  "actionLabel": "EVACUATE",
  "identifyBy": [
    "ST elevation >=1mm in V1 and V2 (septal leads)",
    "May extend to involve anterior territory (V1-V4)",
    "Often associated with LBBB or RBBB (septal infarction disrupts conduction)",
    "V3 transitional - elevation fades toward lateral leads",
    "Septal Q waves may develop (loss of septal depolarisation)"
  ],
  "measurements": {
    "rate": "60-100 bpm",
    "rhythm": "Regular",
    "pWaves": "Normal",
    "prInterval": "May be prolonged or first-degree block",
    "qrsDuration": "May widen (BBB) - often >120ms",
    "qtInterval": "May be prolonged",
    "axis": "Variable",
    "stSegment": "Elevation V1-V2; may involve V3; mild reciprocal inferior changes"
  },
  "management": [
    "12-lead ECG - confirm V1-V2 ST elevation",
    "Consider bundled STEMI protocol - septal MI has high conduction block risk",
    "Aspirin 300mg PO",
    "Analgesia - Morphine or Fentanyl",
    "IV access, monitor for AV block and complete heart block",
    "Urgent evacuation",
    "If complete heart block develops - transcutaneous pacing ready"
  ],
  "pearls": [
    "Septal STEMI frequently causes complete AV block - have pacing equipment ready",
    "New RBBB in the context of acute chest pain = possible septal infarction",
    "Isolated V1-V2 ST elevation may represent posterior STEMI mirror - check V7-V9",
    "Septal infarcts often co-present with anterior infarcts (proximal LAD occlusion)"
  ],
  "differentials": [
    "Anterior STEMI (extending to V3-V4)",
    "Posterior STEMI (reciprocal changes in V1-V2)",
    "Brugada pattern (V1-V2 coved ST, no reciprocal changes)",
    "LBBB",
    "RBBB"
  ],
