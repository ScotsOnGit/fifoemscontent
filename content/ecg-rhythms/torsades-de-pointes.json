  "management": [
    "If pulseless: defibrillate 200J biphasic, begin CPR",
    "Magnesium sulfate 2g IV over 1–2 minutes (drug of choice)",
    "Correct reversible causes: hypokalemia, hypomagnesemia, drugs",
    "Overdrive pacing if refractory",
    "Withhold QT-prolonging drugs"
